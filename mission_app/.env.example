# Go4Me API Configuration
# Renomeie este arquivo para .env e preencha as chaves reais.

# SUPABASE CONFIG
SUPABASE_URL=https://your-project-url.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# STRIPE CONFIG
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# JOSHUA PROJECT CONFIG
JOSHUA_PROJECT_API_KEY=your-api-key
